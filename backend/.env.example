# FastAPI Configuration
DEBUG=True
APP_NAME=AI Analytics Dashboard
APP_VERSION=1.0.0

# Database Configuration
# For local development with SQLite (no PostgreSQL needed):
DATABASE_URL=sqlite:///./analytics.db

# For production with PostgreSQL, use:
# DATABASE_URL=postgresql://user:password@localhost:5432/analytics_db

# Supabase Configuration (Optional - for auth only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# SUPABASE_JWT_SECRET is no longer required when using Supabase JWKS validation.

# Groq API Configuration
GROQ_API_KEY=your-groq-api-key

# File Upload Configuration
UPLOAD_DIRECTORY=./uploads
MAX_UPLOAD_SIZE=52428800  # 50MB in bytes

# Supabase Storage (Optional)
SUPABASE_STORAGE_BUCKET=analytics-files
